# Supabase - crea tu proyecto en https://supabase.com
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Backend API (bartez-backend)
VITE_BACKEND_URL=http://localhost:8787   # dev — cambiar a https://api.bartez.com.ar en prod

# AIR API — Opción A (recomendada): token estático obtenido desde el portal AIR
AIR_API_TOKEN=
# AIR API — Opción B: credenciales para auto-login (el proxy obtiene el token automáticamente)
AIR_API_USER=
AIR_API_PASS=
# (AIR_API_URL no se usa en el proxy — está hardcodeado en api/air-proxy.ts)

# ELIT API
ELIT_API_USER_ID=
ELIT_API_TOKEN=

# Image search (image-finder serverless function)
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

# MercadoLibre API (requerido para buscar imágenes en ML)
MERCADOLIBRE_ACCESS_TOKEN=

# Google Ads API (solo para Edge Functions — cargar en Supabase Dashboard > Edge Functions > Secrets)
# Docs: https://developers.google.com/google-ads/api/docs/get-started/oauth-cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=     # ID sin guiones, ej: 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=   # opcional: MCC/manager ID si el refresh token pertenece a una cuenta administradora
GOOGLE_ADS_API_VERSION=v23      # opcional: version REST activa de Google Ads API

# Anthropic / Claude API (solo para Edge Functions — cargar en Supabase Dashboard > Edge Functions > Secrets)
ANTHROPIC_API_KEY=

# SMTP / correo transaccional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=pedidos@bartez.com.ar
ADMIN_EMAIL=pedidos@bartez.com.ar
