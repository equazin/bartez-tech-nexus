{
  "redirects": [
    {
      "source": "/sitemap.xml",
      "has": [{ "type": "host", "value": "bartez.com.ar" }],
      "destination": "https://www.bartez.com.ar/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/robots.txt",
      "has": [{ "type": "host", "value": "bartez.com.ar" }],
      "destination": "https://www.bartez.com.ar/robots.txt",
      "permanent": true
    },

    { "source": "/producto/:slug*", "destination": "/", "permanent": true },
    { "source": "/arrepentimiento", "destination": "/", "permanent": true },
    { "source": "/arrepentimiento/:path*", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]
}
