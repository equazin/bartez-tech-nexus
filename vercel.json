{
  "cleanUrls": true,
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/arrepentimiento", "destination": "/", "permanent": true },
    { "source": "/arrepentimiento/:path*", "destination": "/", "permanent": true },

    { "source": "/producto/:slug*", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
